                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_ErdhzH": {
                      "type": "text",
                      "settings": {
                        "custom_class": "",
                        "text": "<p><strong>Fibroblast Growth Factors:</strong> Help support collagen-related functions for firmer, smoother-looking skin.</p><p><strong>Epidermal Growth Factors:</strong> Support visible cell renewal for a fresher, more refined complexion.</p><p><strong>Anti-Aging Peptides:</strong> Help reduce the look of fine lines, wrinkles, and loss of firmness.</p><p><strong>Sodium Hyaluronate:</strong> Attracts moisture to support a plump, hydrated, dewy skin appearance.</p><p><strong>Niacinamide:</strong> Helps improve visible tone, pore appearance, dullness, and skin clarity.</p>",
                        "width": "100%",
