                    "open_by_default": false,
                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_QQLxBe": {
                      "type": "text",
                      "settings": {
                        "custom_class": "",
                        "text": "<p><strong>Photoaging Defense Support:</strong> Helps address visible aging signs linked to UV exposure and environmental stress.</p><p><strong>Fibroblast Growth Factor Action:</strong> Supports collagen-related skin activity for firmness and elasticity.</p><p><strong>Epidermal Growth Factor Action:</strong> Helps support visible skin renewal and smoother-looking skin.</p><p><strong>Peptide Firming Technology:</strong> Anti-aging peptides help improve the appearance of wrinkles and skin laxity.</p><p><strong>Moisture Barrier Support:</strong> Hydrating actives help skin look plumper, calmer, and more healthier.</p>",
                        "width": "100%",
                        "max_width": "none",
                        "alignment": "left",
                        "type_preset": "rte",
                        "font": "var(--font-body--family)",
                        "font_size": "1rem",
                        "line_height": "normal",
