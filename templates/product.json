              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<h2 class=\"folow-us-instagram-heading h2\" style=\"style=\" --color: var(--color-foreground-heading);\">\n                        <span class=\"instagram-follow\"> Follow us </span>                      \n                          <a href=\"https://www.instagram.com/raebeautifulskin\" class=\"instagram-link-url\">                                                        \n                              <img src=\"{{ 'follow-instagram-image.webp' | file_url }}\" alt=\"follow-instagram-image\" height=\"30\" loading=\"lazy\" width=\"30\" class=\"follow-instagram-image\">\n                              <span> @raebeautifulskin</span>\n                          </a>                      \n                      <style>\n                        .follow-instagram-image {\n                              height: 30px;\n                                width: 30px;\n                                aspect-ratio: 1 / 1;\n                            }\n.folow-us-instagram-heading a{\ncolor: #377e99 !important;\nfont-style: italic;\n}\n                            .folow-us-instagram-heading {\n       font-family: 'Catchy Mager' !important;                       display: flex;\n                                align-items: center;\n                                gap: 10px;\n    color: #377e99 !important;\n                            }\n\n                            .instagram-link-url {\n                                display: flex;\n                                justify-content: center;\n                                align-items: center;\n                                gap: 5px;\n                            }\n\n                            .instagram-link-url:hover {\n                                transform: translateY(-2px);\n-webkit-transform: translateY(-2px); /* Safari and older Chrome versions */\n-ms-transform: translateY(-2px); /* IE 9 */\ntransition: transform 0.3s ease;\n-webkit-transition: transform 0.3s ease; /* Safari and older Chrome versions */\n-ms-transition: transform 0.3s ease; /* IE 10 */\n                            } \n                            @media screen and (max-width: 600px)  {\n                              .folow-us-instagram-heading {\n                                  flex-direction: column;\n                                  gap: 5px;\n                              }\n\n                              .instagram-link-url {\n                                  border: 1px solid lightgray;\n                                  padding: 5px 10px;\n                                  border-radius: 10px;\n                              }\n.instagram-follow {\n    text-transform: uppercase;\n}\n.follow-instagram-image {\n    height: 23px;\n    width: 23px;\n}\n.folow-us-instagram-heading a{\nfont-size: 22px;\n}\n                            }\n                      </style>\n                  </h2>"
