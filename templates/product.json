                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_RmJmbt": {
                      "type": "text",
                      "settings": {
                        "custom_class": "",
                        "text": "<p><strong>Wrinkle Visibility Support:</strong> Helps reduce the appearance of fine lines and wrinkles for smoother-looking skin.</p><p><strong>Skin Structure Improvement: </strong> Helps improve the appearance of skin firmness, elasticity, and smoothness for a more youthful-looking complexion. </p><p><strong>Texture Refinement:</strong> Improves the look of rough, uneven skin texture for a softer surface.</p><p><strong>Tone Correction Support:</strong> Helps visibly improve uneven tone, dullness, and pigmentation concerns.</p><p><strong>Radiance Recovery:</strong> Revives tired-looking skin for a brighter, fresher, more youthful appearance.</p>",
                        "width": "100%",
                        "max_width": "none",
                        "alignment": "left",
                        "type_preset": "rte",
                        "font": "var(--font-body--family)",
                        "font_size": "1rem",
                        "line_height": "normal",
                        "letter_spacing": "normal",
