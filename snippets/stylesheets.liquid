{{ 'overflow-list.css' | asset_url | preload_tag: as: 'style' }}
{{ 'base.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'custom-font.css' | asset_url | stylesheet_tag: preload: true }}

{% if request.page_type == 'index' %}
    {{ 'homepage.css' | asset_url | preload_tag: as: 'style' }}
    <link rel="stylesheet"
        href="{{ 'homepage.css' | asset_url }}"
        media="print"
        onload="this.media='all'">
    <noscript>
    {{ 'homepage.css' | asset_url | stylesheet_tag }}
    </noscript>
{% endif %}

{% if request.page_type 'product' %}
    {{ 'product-page.css' | asset_url | preload_tag: as: 'style' }}
    <link rel="stylesheet"
        href="{{ 'product-page.css' | asset_url }}"
        media="print"
        onload="this.media='all'">
    <noscript>
    {{ 'product-page.css' | asset_url | stylesheet_tag }}
    </noscript>
{% endif %}

