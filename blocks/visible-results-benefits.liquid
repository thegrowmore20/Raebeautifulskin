
{%- assign benefit_keys = 'b1,b2,b3,b4,b5' | split: ',' -%}

<div class="vrb-grid" {{ block.shopify_attributes }}>
  {%- for key in benefit_keys -%}
    {%- assign title_key     = key | append: '_title'     -%}
    {%- assign desc_key      = key | append: '_desc'      -%}
    {%- assign icon_key      = key | append: '_icon'      -%}
    {%- assign img_key       = key | append: '_img'       -%}
    {%- assign img_width_key = key | append: '_img_width' -%}
    <div class="vrb-item">
      <div class="vrb-top-row">
        <div class="vrb-badge">0{{ forloop.index }}</div>
        {%- if block.settings[img_key] != blank -%}
          {%- assign img_w = block.settings[img_width_key] -%}
          <div class="vrb-icon" style="--vrb-img-w:{{ img_w }}px">
            {{- block.settings[img_key] | image_url: width: 120 | image_tag: loading: 'lazy' -}}
          </div>
        {%- elsif block.settings[icon_key] != 'none' -%}
          <div class="vrb-icon">
            {%- render 'icon-or-image', icon: block.settings[icon_key], width: 22 -%}
          </div>
        {%- endif -%}
      </div>
      <div class="vrb-line"></div>
      <p class="vrb-title">{{ block.settings[title_key] }}</p>
      <p class="vrb-desc">{{ block.settings[desc_key] }}</p>
    </div>
  {%- endfor -%}
</div>

{% stylesheet %}
/* Grid container */
.vrb-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  background: #ffffff;
  border-radius: 16px;
  width: 100%;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08), 0 1px 4px rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

/* Each column */
.vrb-item {
  flex: 1 1 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 28px 20px;
  min-width: 0;
  box-sizing: border-box;
}
.vrb-item:not(:last-child) {
  border-right: 1px solid rgba(0, 0, 0, 0.08);
}

/* Badge + icon row */
.vrb-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* Numbered circle */
.vrb-badge {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #377e99;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.8125rem;
  font-weight: 700;
  flex-shrink: 0;
  letter-spacing: 0.5px;
}

/* Icon next to badge */
.vrb-icon {
  opacity: 0.3;
  display: flex;
  align-items: center;
  flex-shrink: 0;
}
.vrb-icon img {
  display: block;
  width: var(--vrb-img-w, 28px);
  height: auto;
  max-width: none;
}

/* Short teal divider */
.vrb-line {
  width: 28px;
  height: 2px;
  background: #377e99;
  border-radius: 2px;
  flex-shrink: 0;
}

.vrb-title {
  font-weight: 700;
  margin: 0;
  line-height: 1.35;
  font-size: 0.875rem;
}

.vrb-desc {
  margin: 0;
  font-size: 0.8125rem;
  line-height: 1.55;
  opacity: 0.7;
}

/* ── iPad / Tablet (768–999px): row 1 = 3 cols, row 2 = 2 cols (50% each) ── */
@media screen and (max-width: 999px) and (min-width: 768px) {
  .vrb-grid {
    flex-wrap: wrap;
  }
  /* Row 1: items 1-3 at 33.333% */
  .vrb-item {
    flex: 0 0 33.333%;
    max-width: 33.333%;
    padding: 24px 18px;
    gap: 10px;
  }
  /* Row 2: items 4 & 5 at 50% each */
  .vrb-item:nth-child(4),
  .vrb-item:nth-child(5) {
    flex: 0 0 50%;
    max-width: 50%;
  }
  /* Reset all desktop right borders */
  .vrb-item:not(:last-child) {
    border-right: none;
  }
  /* Row 1 right borders: items 1 & 2 (not 3rd) */
  .vrb-item:nth-child(1),
  .vrb-item:nth-child(2) {
    border-right: 1px solid rgba(0, 0, 0, 0.08);
  }
  /* Row 2 right border: item 4 only */
  .vrb-item:nth-child(4) {
    border-right: 1px solid rgba(0, 0, 0, 0.08);
  }
  /* Bottom border under row 1 */
  .vrb-item:nth-child(-n+3) {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
  /* Last item: no borders */
  .vrb-item:last-child {
    border-right: none;
    border-bottom: none;
  }
}

/* ── Mobile (≤767px): 2-per-row, last item full width ── */
@media screen and (max-width: 767px) {
  .vrb-grid {
    flex-wrap: wrap;
  }
  .vrb-item {
    flex: 0 0 50%;
    max-width: 50%;
  }
  /* Reset desktop right borders, re-apply only col-1 of each row */
  .vrb-item:not(:last-child) {
    border-right: none;
  }
  .vrb-item:nth-child(odd):not(:last-child) {
    border-right: 1px solid rgba(0, 0, 0, 0.08);
  }
  /* Bottom border under rows 1 & 2 (first 4 items) */
  .vrb-item:nth-child(-n+4) {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
  /* Last (5th) item spans full width */
  .vrb-item:last-child {
    flex: 0 0 100%;
    max-width: 100%;
    border-right: none;
    border-bottom: none;
  }
}

/* ── Small mobile (≤479px): single column ── */
@media screen and (max-width: 479px) {
  .vrb-item {
    flex: 0 0 100%;
    max-width: 100%;
    border-right: none !important;
  }
  .vrb-item:not(:last-child) {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
}
{% endstylesheet %}

