<style>

  :root {
    --rae-bg-start: #eaf2f6;
    --rae-bg-end: #f5f9fb;
    --rae-card-bg: #ffffff;
    --rae-card-border: #377E99;
    --rae-primary: #1f4f63;
    --rae-text: #2a3f4a;
    --rae-muted: #5a7080;
    --rae-line: #b6c9d4;
  }

.rae-patents {
  color: var(--rae-text);
  background: linear-gradient(180deg, var(--rae-bg-start) 0%, var(--rae-bg-end) 100%);
  padding: clamp(2.5rem, 6vw, 5rem) clamp(1rem, 4vw, 3rem);
  position: relative;
  overflow: hidden;
}

.patent-footer-group {
    max-width: 700px;   
     margin-left: auto;
    margin-right: auto;
}


.rae-patents__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
  max-width: 1200px;
  margin: 0 auto;
  align-items: center;
  position: relative;
}
.rae-patents__col {
  display: grid;
  gap: 1rem;
}

.rae-patents__card {  
  border: 1px solid var(--rae-card-border);
  border-radius: 14px;
  padding: clamp(1rem, 2.5vw, 1.75rem) clamp(0.75rem, 2vw, 1.5rem);
  text-align: center;
  position: relative;
  min-height: 150px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.6rem;
  box-shadow: 0 1px 3px rgba(31, 79, 99, 0.04);
}
.rae-patents__flag {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: 0 1px 2px rgba(0,0,0,0.08);
}
.rae-patents__flag svg { width: 100%; height: 100%; display: block; }

.rae-patents__country {
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  color: var(--rae-primary);
}
.rae-patents__divider {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  color: var(--rae-line);
  font-size: 0.6rem;
}
.rae-patents__divider::before,
.rae-patents__divider::after {
  content: "";
  width: 14px;
  height: 1px;
  background: var(--rae-line);
}
.rae-patents__divider span { color: var(--rae-line); }

.rae-patents__benefit {
  font-size: clamp(0.8rem, 1.5vw, 0.9rem);
  font-weight: 500;
  color: var(--rae-text);
  margin: 0;
  line-height: 1.35;
}

.rae-patents__center {
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  padding: 0.5rem;
  min-height: 320px;
}

.rae-patents__product {
  position: relative;
  z-index: 1;
  width: clamp(170px, 28vw, 360px);
  height: auto;
  aspect-ratio: 280 / 400;
  object-fit: contain;
}

.rae-patents__footer {
  max-width: 760px;
  margin: clamp(2rem, 5vw, 3rem) auto 0;
  background: var(--rae-card-bg);
  border: 1px solid var(--rae-card-border);
  border-radius: 14px;
  padding: clamp(1rem, 2.5vw, 1.5rem) clamp(1rem, 3vw, 2rem);
  display: flex;
  align-items: center;
  gap: 1.25rem;
  text-align: left;
  box-shadow: 0 1px 3px rgba(31, 79, 99, 0.04);
}
.rae-patents__beaker {
  flex-shrink: 0;
  width: 52px;
  height: 52px;
  color: var(--rae-primary);
}
.rae-patents__footer-text {
  font-size: clamp(0.9rem, 1.5vw, 1rem);
  line-height: 1.5;
  margin: 0;
  color: var(--rae-muted);
}
.rae-patents__footer-text strong {
  color: var(--rae-primary);
  font-weight: 600;
  display: block;
  margin-top: 0.15rem;
}
.patent-footer-note strong {
  color: var(--rae-primary);
}

[style*="--horizontal-alignment: center"]>.patent-footer-note.text-block {
    --text-align-default: left;
}

@media (min-width: 768px) {
  .rae-patents__grid {
    grid-template-columns: 1fr auto 1fr;
    gap: clamp(1rem, 4vw, 3.5rem);
  }
  .rae-patents__col { gap: 1rem; }
}

/* ============ Desktop layout (≥ 900px) ============ */
@media (min-width: 900px) {
  

  /* Decorative connecting lines from cards toward the bottle */
  
  .rae-patents__col--left  .rae-patents__card::after,
  .rae-patents__col--right .rae-patents__card::after {
    content: "";
    position: absolute;
    top: 18%;
    height: 100%;
    {% comment %} background: var(--rae-line); {% endcomment %}
    
    {% comment %} width: clamp(0.75rem, 3vw, 2.25rem); {% endcomment %}
     width: 100px;
  }
  .rae-patents__col--left  .rae-patents__card::after { right: calc(-1 * clamp(0.75rem, 3vw, 2.25rem)); }
  .rae-patents__col--right .rae-patents__card::after { left:  calc(-1 * clamp(0.75rem, 3vw, 2.25rem)); }
  .rae-patents__col--left  .rae-patents__card::after {
    background: url('https://cdn.shopify.com/s/files/1/0704/7253/2264/files/line.png?v=1779189187');
    right: -100px;
    left: auto;
    background-size: 100px;
    background-repeat: no-repeat;
  }
  .rae-patents__col--right .rae-patents__card::after {
    background: url('https://cdn.shopify.com/s/files/1/0704/7253/2264/files/line-2.png?v=1779189188');
    left: -100px;
    background-size: 100px;
    background-repeat: no-repeat;
  }
}

/* ============ Mobile layout (< 900px) ============ */
@media (max-width: 767px) {
  .rae-patents__center { order: -1; margin-bottom: 0rem; }
  .rae-patents__col { grid-template-columns: 1fr 1fr; gap: 1rem; }
  .rae-patents__card { min-height: 160px; padding: 10px; }
  .rae-patents__footer { flex-direction: column; text-align: center; gap: 0.75rem; }
}

@media (max-width: 750px) {
  .patent-footer-group-inner .group-block-content.layout-panel-flex {
    justify-content: center;
    align-items: center;
    text-align: center;
  }
  .patent-footer-group-inner .group-block-content.layout-panel-flex rte-formatter p {
    font-size: 14px;
  }
  .rae-patents__country {
    letter-spacing: 0;
  }
  .rae-patents__center {
    min-height: 280px;
  }
}

@media (max-width: 480px) {
  .rae-patents__grid {
    gap: 10px;
  }
  .rae-patents__col { grid-template-columns: repeat(2, 1fr); gap: 10px }
  [style*="--horizontal-alignment: center"]>.patent-footer-note.text-block {
    --text-align-default: left;
}
}

