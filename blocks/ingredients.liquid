{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
    assign metafield_namespace = block.settings.metafield_namespace
    assign metafield_key = block.settings.metafield_key
    assign metaobject_type = block.settings.metaobject_type_reference
    assign ingredients = product.metafields[metafield_namespace][metafield_key].value
  
    if block.settings.enable_metaobject and block.settings.metaobject_type_reference != blank
      assign ingredients = shop.metaobjects[metaobject_type].values
    elsif block.settings.metafield_namespace != blank and block.settings.metafield_key != blank
      assign ingredients = product.metafields[metafield_namespace][metafield_key].value
    endif
%}


{% style %}
  .ai-ingredient-slider-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-ingredient-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
    padding: 10px 0;
  }

  .ai-ingredient-slider-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: grab;
    user-select: none;
  }

  .ai-ingredient-slider-track-{{ ai_gen_id }}.dragging {
    cursor: grabbing;
    transition: none;
  }

  .ai-ingredient-card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - (3 * {{ block.settings.card_gap }}px)) / 4);
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    {% if block.settings.enable_border %}
      border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {% else %}
      border: none;
    {% endif %}
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
  }

  .ai-ingredient-card-{{ ai_gen_id }}:nth-of-type(even) {
    flex-direction: column-reverse;
  }

  .ai-ingredient-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    padding: {{ block.settings.image_padding }}px;
  }

  .ai-ingredient-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-ingredient-content-{{ ai_gen_id }} {
    padding: {{ block.settings.text_padding }}px;
  }

  .ai-ingredient-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_font_size }}px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .ai-ingredient-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    line-height: 1.5;
  }

  .ai-ingredient-slider-controls-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-top: 30px;
  }

  .ai-ingredient-slider-arrow-{{ ai_gen_id }} {
    background-color: {{ block.settings.arrow_background }};
    border: {{ block.settings.arrow_border_width }}px solid {{ block.settings.arrow_border_color }};
    border-radius: {{ block.settings.arrow_border_radius }}px;
    cursor: pointer;
    padding: {{ block.settings.arrow_size }}px;
    display: {% if block.settings.show_arrows %}flex{% else %}none{% endif %};
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-ingredient-slider-arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_background }};
    border-color: {{ block.settings.arrow_hover_border_color }};
  }

  .ai-ingredient-slider-arrow-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-ingredient-slider-arrow-{{ ai_gen_id }} svg {
    width: {{ block.settings.arrow_icon_size }}px;
    height: {{ block.settings.arrow_icon_size }}px;
    stroke: {{ block.settings.arrow_color }};
    stroke-width: 2;
  }

  .ai-ingredient-slider-arrow-{{ ai_gen_id }}:hover svg {
    stroke: {{ block.settings.arrow_hover_color }};
  }

  .ai-ingredient-slider-dots-{{ ai_gen_id }} {
    display: {% if block.settings.show_dots %}flex{% else %}none{% endif %};
    gap: {{ block.settings.dot_spacing }}px;
  }

  .ai-ingredient-slider-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: {{ block.settings.dot_border_radius }}px;
    background-color: {{ block.settings.dot_color }};
    opacity: {{ block.settings.dot_inactive_opacity | divided_by: 100.0 }};
    border: {{ block.settings.dot_border_width }}px solid {{ block.settings.dot_border_color }};
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }

  .ai-ingredient-slider-dot-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.dot_hover_color }};
    opacity: 1;
  }

  .ai-ingredient-slider-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    opacity: 1;
  }

  @media screen and (max-width: 992px) {
    .ai-ingredient-card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - (2 * {{ block.settings.card_gap }}px)) / 3);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-ingredient-card-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }
    .ai-ingredient-slider-arrow-{{ ai_gen_id }} svg {
      width: {{ block.settings.arrow_icon_size | times: 0.75 }}px;
      height: {{ block.settings.arrow_icon_size | times: 0.75 }}px;
    }
    .ai-ingredient-slider-arrow-{{ ai_gen_id }} {
      padding: {{ block.settings.arrow_size | times: 0.75 }}px;
    }
    .ai-ingredient-card-{{ ai_gen_id }}:nth-of-type(even) {
      flex-direction: column;
    }
  }
{% endstyle %}

<ingredient-slider-{{ ai_gen_id }}
  class="ai-ingredient-slider-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-ingredient-slider-wrapper-{{ ai_gen_id }}">
    <div class="ai-ingredient-slider-track-{{ ai_gen_id }}" data-slider-track>
      {% if ingredients %}
       {% assign sorted_ingedients = ingredients | sort: 'sorting' %}
        {% for ingredient in sorted_ingedients %}
          <style>
            .item-background-color-{{ ai_gen_id }}-{{ forloop.index }} {
              background-color: {{ ingredient.background_color.value }};
            }
          </style>
          <div class="ai-ingredient-card-{{ ai_gen_id }} {% if ingredient.background_color.value == blank %}color-{{ block.settings.color_scheme }} gradient{% else %}item-background-color-{{ ai_gen_id }}-{{ forloop.index }}{% endif %}">
            {% if ingredient.image %}
              <div class="ai-ingredient-image-wrapper-{{ ai_gen_id }}">
                <img
                  src="{{ ingredient.image | image_url: width: 400 }}"
                  alt="{{ ingredient.name | escape }}"
                  loading="lazy"
                  width="400"
                  height="400"
                  class="ai-ingredient-image-{{ ai_gen_id }}"
                >
              </div>
            {% endif %}

            <div class="ai-ingredient-content-{{ ai_gen_id }}">
              {% if ingredient.name %}
                <h3 class="ai-ingredient-name-{{ ai_gen_id }}">{{ ingredient.name }}</h3>
              {% endif %}

              {% if ingredient.description %}
                <div class="ai-ingredient-description-{{ ai_gen_id }}">
                  {{ ingredient.description | metafield_tag }}
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..8) %}
          <div class="ai-ingredient-card-{{ ai_gen_id }} color-{{ block.settings.color_scheme }} gradient">
            <div class="ai-ingredient-image-wrapper-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
            <div class="ai-ingredient-content-{{ ai_gen_id }}">
              <h3 class="ai-ingredient-name-{{ ai_gen_id }}">Ingredient {{ i }}</h3>
              <div class="ai-ingredient-description-{{ ai_gen_id }}">
                Add your ingredients using the metafield settings to display them here.
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    <div class="ai-ingredient-slider-controls-{{ ai_gen_id }}">
      <button
        class="ai-ingredient-slider-arrow-{{ ai_gen_id }} ai-ingredient-slider-prev-{{ ai_gen_id }}"
        aria-label="Previous slide"
        data-prev
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
          <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="ai-ingredient-slider-dots-{{ ai_gen_id }}" data-dots></div>

      <button
        class="ai-ingredient-slider-arrow-{{ ai_gen_id }} ai-ingredient-slider-next-{{ ai_gen_id }}"
        aria-label="Next slide"
        data-next
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
          <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</ingredient-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class IngredientSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.isDragging = false;
        this.startPos = 0;
        this.dragEndPos = null;
      }

      connectedCallback() {
        this.track = this.querySelector('[data-slider-track]');
        this.prevBtn = this.querySelector('[data-prev]');
        this.nextBtn = this.querySelector('[data-next]');
        this.dotsContainer = this.querySelector('[data-dots]');
        this.cards = this.querySelectorAll('.ai-ingredient-card-{{ ai_gen_id }}');

        this.updateSlidesPerView();
        this.createDots();
        this.setupEventListeners();
        this.updateSlider();

        window.addEventListener('resize', () => {
          this.updateSlidesPerView();
          this.createDots();
          this.updateSlider();
        });
      }

      updateSlidesPerView() {
        const width = window.innerWidth;
        if (width <= 749) {
          this.slidesPerView = 1;
        } else if (width <= 992) {
          this.slidesPerView = 3;
        } else {
          this.slidesPerView = 4;
        }
        this.totalSlides = Math.max(0, this.cards.length - this.slidesPerView + 1);
      }

      createDots() {
        if (!this.dotsContainer) return;
        this.dotsContainer.innerHTML = '';

        for (let i = 0; i < this.totalSlides; i++) {
          const dot = document.createElement('button');
          dot.classList.add('ai-ingredient-slider-dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          if (i === this.currentIndex) {
            dot.classList.add('active');
          }
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      setupEventListeners() {
        if (this.prevBtn) {
          this.prevBtn.addEventListener('click', () => this.prev());
        }
        if (this.nextBtn) {
          this.nextBtn.addEventListener('click', () => this.next());
        }

        this.track.addEventListener('mousedown', this.touchStart.bind(this));
        this.track.addEventListener('touchstart', this.touchStart.bind(this), { passive: true });
        this.track.addEventListener('mouseup', this.touchEnd.bind(this));
        this.track.addEventListener('touchend', this.touchEnd.bind(this));
        this.track.addEventListener('mousemove', this.touchMove.bind(this));
        this.track.addEventListener('touchmove', this.touchMove.bind(this), { passive: false });
        this.track.addEventListener('mouseleave', this.touchEnd.bind(this));

        this.track.addEventListener('dragstart', (e) => e.preventDefault());
      }

      touchStart(event) {
        this.isDragging = true;
        this.dragEndPos = null;
        this.startPos = event.type.includes('mouse')
          ? event.pageX
          : event.touches[0].clientX;
        this.track.classList.add('dragging');
      }

      touchMove(event) {
        if (!this.isDragging) return;
        const currentPosition = event.type.includes('mouse')
          ? event.pageX
          : event.touches[0].clientX;
        this.dragEndPos = currentPosition;
        const diff = currentPosition - this.startPos;
        if (Math.abs(diff) > 5) {
          event.preventDefault();
        }
      }

      touchEnd(event) {
        if (!this.isDragging) return;
        this.isDragging = false;
        this.track.classList.remove('dragging');

        const movedBy = this.dragEndPos !== null
          ? this.dragEndPos - this.startPos
          : 0;

        if (movedBy < -50 && this.currentIndex < this.totalSlides - 1) {
          this.next();
        } else if (movedBy > 50 && this.currentIndex > 0) {
          this.prev();
        }
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateSlider();
        }
      }

      next() {
        if (this.currentIndex < this.totalSlides - 1) {
          this.currentIndex++;
          this.updateSlider();
        }
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateSlider();
      }

      updateSlider() {
        const cardWidth = this.cards[0].offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const offset = -(this.currentIndex * (cardWidth + gap));

        this.track.style.transform = `translateX(${offset}px)`;

        if (this.prevBtn) {
          this.prevBtn.disabled = this.currentIndex === 0;
        }
        if (this.nextBtn) {
          this.nextBtn.disabled = this.currentIndex >= this.totalSlides - 1;
        }

        const dots = this.dotsContainer.querySelectorAll('.ai-ingredient-slider-dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === this.currentIndex);
        });
      }
    }

    customElements.define('ingredient-slider-{{ ai_gen_id }}', IngredientSlider{{ ai_gen_id }});
  })();
</script>

