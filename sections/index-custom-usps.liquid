

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
	class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
	data-testid="ui-test-section"
	{% if request.visual_preview_mode %}
		data-shopify-visual-preview
	{% endif %}
	style="
    {% if section.settings.section_height == 'custom' %}
      --section-min-height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == 'full-screen' %}
      --section-min-height: 100svh;
    {% elsif section.settings.section_height != '' %}
      --section-min-height: var(--section-height-{{ section.settings.section_height }});
    {% endif %}
	
    {% if section.settings.section_height != '' %}
     --section-preview-height: 600px;
     {% endif %}
  "
>
	<div class="custom-section-background">
		{% render 'background-media',
			background_media: section.settings.background_media,
			background_video: section.settings.video,
			background_video_position: section.settings.video_position,
			background_image: section.settings.background_image,
			background_image_position: section.settings.background_image_position
		%}
	</div>
	
	<div
		class="border-style custom-section-content"
		style="{% render 'border-override', settings: section.settings %}"
	>
		{% if section.settings.toggle_overlay %}
			{% render 'overlay', settings: section.settings, layer: '0' %}
		{% endif %}
		
		<div
			class="
        spacing-style
        layout-panel-flex
        layout-panel-flex--{{ section.settings.content_direction }}
        section-content-wrapper
        {% if section.settings.vertical_on_mobile %} mobile-column{% endif %}
      "
			style="
        {% render 'layout-panel-style', settings: section.settings %}
        {% render 'spacing-style', settings: section.settings %}
      "
			data-testid="section-content"
		>
			<div class="section-body trim-margins">
				<div class="services-container {% if section.settings.vertical_layout %}services-vertical-layout text-center{% endif %}">
					<div class="services-intro {% if section.settings.show_divider %}has-divider{% endif %}">
						<h2 class="uppercase">{{ section.settings.heading | escape }}</h2>
						{% if section.settings.text_1 != blank %}
							<p>{{ section.settings.text_1 }}</p>
						{% endif %}
						<div class="intro-images">
							{% if section.settings.intro_img_1 != blank %}						
							{{ section.settings.intro_img_1 | image_url: width: 280 | image_tag: width: 280, alt: section.settings.intro_img_1.alt, loading: 'lazy' }}
						{% endif %}
						{% if section.settings.intro_img_2 != blank %}
							{{ section.settings.intro_img_2 | image_url: width: 280 | image_tag: width: 280, alt: section.settings.intro_img_2.alt, loading: 'lazy' }}
						{% endif %}
					</div>
				</div>
				<div class="services-grid">
					{% for block in section.blocks %}
						<div class="service-card" {{ block.shopify_attributes }}>
							{% if block.settings.icon_html != blank %}
								<div class="service-icon">
									{{ block.settings.icon_html }}
								</div>
							{% elsif block.settings.icon_image != blank %}
								<div class="service-icon">
									<img src="{{ block.settings.icon_image | image_url }}" alt="{{ block.settings.title | escape }}"
										loading="lazy" width="" height="">
									</div>
								{% endif %}
								
								<h3>{{ block.settings.title | escape }}</h3>
								<p>{{ block.settings.text }}</p>
								
								{% if block.settings.link_label != blank and block.settings.link_url != blank %}
									<a href="{{ block.settings.link_url }}" class="service-link" style="color: {{ section.settings.link_color }};">{{ block.settings.link_label | escape }}</a>
								{% endif %}
							</div>
						{% endfor %}
					</div>
				</div>
			</div>
			
			
		</div>
	</div>
</div>

{% stylesheet %}
.section-wrapper {
	--section-height-offset: 0px;
}

.section[data-shopify-visual-preview] {
	min-height: var(--section-preview-height);
	padding-top: 0;
}

.section[data-shopify-visual-preview] .custom-section-background {
	display: none;
}

body:has(> #header-group > .header-section > #header-component[transparent]):not(
	:has(> #header-group > .header-section + .shopify-section)
)
> main
> .section-wrapper:first-child {
	--section-height-offset: var(--header-group-height, 0);
}

.custom-section-background {
	grid-column: 1 / -1;
}

.custom-section-content {
	z-index: var(--layer-flat);
}
{% endstylesheet %}


<style>
	.section-body.trim-margins {
    max-width: 1200px;
    margin: 0 auto;
	}
	/* CSS adapted for section id wrapper to prevent conflicts */
	#shopify-section-{{ section.id }} .services-container {
		color: #ffffff;
		width: 100%;
		border-radius: 8px;
		display: flex;
		gap: 80px;
	}
	
	#shopify-section-{{ section.id }} .services-container.services-vertical-layout {
		flex-direction: column;
		gap: 50px;
	}
	
	#shopify-section-{{ section.id }} .services-intro {
		flex: 0 0 35%;
		display: flex;
		flex-direction: column;
		position: relative;
		border: 1px solid;
		border-radius: 12px;
		padding: 2rem;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
	}
	#shopify-section-{{ section.id }} .services-intro.has-divider::after {
		content: '';
		position: absolute;
		right: -40px;
		top: 0;
		bottom: 0;
		width: 1px;
		background-color: rgba(255, 255, 255, 0.2);
	}
	#shopify-section-{{ section.id }} .services-container.services-vertical-layout .services-intro.has-divider::after {
		width: 100%;
		height: 1px;
		top: auto;
		bottom: -30px;
		right: 0;
		left: 0;
	}
	#shopify-section-{{ section.id }} .services-intro h2 {
		font-size: 2.2rem;
		line-height: 1.25;
		margin-bottom: 24px;					;
		color: #ffffff;
	}
	#shopify-section-{{ section.id }} .services-intro p {
		font-size: 1rem;
		line-height: 1.6;
		margin-bottom: 24px;
		color: #e0e0e0;
	}
	#shopify-section-{{ section.id }} .intro-images {
		display: flex;
		flex-wrap: wrap;
		gap: 20px;
		margin-top: 16px;
		justify-content: center;
		align-items: center;
	}
	#shopify-section-{{ section.id }} .intro-images img {
		max-width: 180px;
		height: auto;
		object-fit: contain;
	}
	#shopify-section-{{ section.id }} .services-container.services-vertical-layout .intro-images img {
		max-width: 275px;
	}
	#shopify-section-{{ section.id }} .services-grid {
		flex: 1;
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		grid-row-gap: 25px;
		grid-column-gap: 25px;
	}
	#shopify-section-{{ section.id }} .services-container.services-vertical-layout .services-grid {
		grid-template-columns: repeat(4, 1fr);
	}
	#shopify-section-{{ section.id }} .service-card {
		display: flex;
		flex-direction: column;
		background-color: #202020;
		padding: 2rem 1rem;		
		border-radius: 12px;	
	}
	#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-card {
		align-items: center;
	}
	#shopify-section-{{ section.id }} .service-icon {
		width: 68px;
		height: 68px;
		margin-bottom: 20px;
		display: flex;
		align-items: center;
		justify-content: flex-start;
		color: #ffffff;
	}
	#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-icon {
		width: 80px;
		height: 80px;
		margin-bottom: 20px;
	}
	#shopify-section-{{ section.id }} .service-icon > svg,
	#shopify-section-{{ section.id }} .service-icon > img {
		width: 60px;
		height: 60px;
		object-fit: contain;
	}
	#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-icon > svg,
	#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-icon > img {
		width: 80px;
		height: 80px;
		object-fit: contain;
	}
	#shopify-section-{{ section.id }} .service-card h3 {
		font-size: 1.3rem;
		margin-bottom: 12px;
		font-weight: 600;
		margin-bottom: .5rem;
		color: #ffffff;
	}
	#shopify-section-{{ section.id }} .service-card p {
		font-size: 0.95rem;
		line-height: 1.6;
		color: #e0e0e0;
		margin-bottom: 16px;
		flex-grow: 1;
		margin-bottom: 0;
	}
	#shopify-section-{{ section.id }} .service-link {
		text-decoration: none;
		font-weight: 500;
		font-size: 0.95rem;
	}
	#shopify-section-{{ section.id }} .service-link:hover {
		text-decoration: underline;
	}
	@media screen and (max-width: 992px) {
		#shopify-section-{{ section.id }} .services-container {
			flex-direction: column;
			padding: 40px;
			gap: 50px;
		}
		#shopify-section-{{ section.id }} .services-intro {
			flex: auto;
		}
		#shopify-section-{{ section.id }} .services-intro.has-divider::after {
			display: none;
		}
		#shopify-section-{{ section.id }} .services-container.services-vertical-layout .services-intro.has-divider::after {
			display: block;
		}
	}
	
	@media screen and (max-width: 992px) {
		#shopify-section-{{ section.id }} .services-grid {
			grid-template-columns: 1fr 1fr;
			grid-row-gap: 20px;
		}
		#shopify-section-{{ section.id }} .services-container.services-vertical-layout .services-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		#shopify-section-{{ section.id }} .intro-images img {
			max-width: 20%;
		}
		#shopify-section-{{ section.id }} .intro-images {
			flex-wrap: nowrap;
			justify-content: center;
			align-items: center;
		}
		
		
		#shopify-section-{{ section.id }} .services-container{
			padding: 0;
		}
		
	}
	@media screen and (max-width: 767px) {
		#shopify-section-{{ section.id }} .services-grid {
			grid-template-columns: 1fr;
			grid-row-gap: 20px;
		}
		#shopify-section-{{ section.id }} .services-container.services-vertical-layout .services-grid {
			grid-template-columns: repeat(2, 1fr);
			column-gap: 15px
		}
		
		#shopify-section-{{ section.id }} .intro-images {        
			justify-content: flex-start;        
		}
		
		#shopify-section-{{ section.id }} .intro-images img {
			max-width: 45%;
		}
		
		#shopify-section-{{ section.id }} .services-container.services-vertical-layout .intro-images img {
			max-width: calc(50% - 10px);
		}
		
		#shopify-section-{{ section.id }} .services-container{
			padding: 10px 0;
			gap: 40px;
		}
		#shopify-section-{{ section.id }} .services-intro h2 {
			font-size: 1.9rem;
		}
		
		#shopify-section-{{ section.id }} .service-card{
			align-items: center;
		}
		#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-card h3 {
			font-size: 1rem;
		}
		#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-icon {
			width: 50px;
			height: 50px;
			margin-bottom: 20px;
		}
		#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-icon > svg,
		#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-icon > img {
			width: 50px;
			height: 50px;
		}
	}
	@media screen and (max-width: 520px) {
		#shopify-section-{{ section.id }} .services-intro {
			padding: 1rem
		}
		#shopify-section-{{ section.id }} .services-intro h2 {
			font-size: 1.6rem;
			margin-bottom: .5rem;
		}
		#shopify-section-{{ section.id }} .services-container.services-vertical-layout {
			gap: 25px;
		}
		#shopify-section-{{ section.id }} .services-container.services-vertical-layout .services-grid {
			gap: 8px;
		}
		#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-card {
			padding: 1rem .5rem;
		}
		#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-card p {
			font-size: 10px;						
		}
		#shopify-section-{{ section.id }} .services-intro p {
			margin-bottom: .5rem;						
		}
	}
</style>
{% schema %}
{
	"name": "General USPs",
	"class": "section-wrapper",
	"settings": [
		{
			"id": "vertical_layout",
			"type": "checkbox",
			"label": "Vertical Layout"
		},
		{
			"type": "checkbox",
			"id": "show_divider",
			"label": "Show Vertical Divider",
			"default": true
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Premium Assurance with Lifetime Support"
		},
		{
			"type": "textarea",
			"id": "text_1",
			"label": "Paragraph",
			"default": "Enjoy peace of mind with our 30-day money-back guarantee and a lifetime warranty, proving our commitment to high-quality, trusted products since 2013."
		},
		{
			"type": "image_picker",
			"id": "intro_img_1",
			"label": "First Intro Image"
		},
		{
			"type": "image_picker",
			"id": "intro_img_2",
			"label": "Second Intro Image"
		},
		{
			"type": "color",
			"id": "link_color",
			"label": "Service Link Color",
			"default": "#ffd814"
		},
		{
			"type": "header",
			"content": "Color Settings"
		},
		{
			"type": "color",
			"label": "Background",
			"id": "background_color"
		},
		{
			"type": "color",
			"label": "Text Color",
			"id": "text_color"
		},
		{
			"type": "color",
			"label": "Heading Color",
			"id": "heading_color"
		},
		{
			"type": "header",
			"content": "Seo Settings"
		},
		{
			"type": "select",
			"id": "heading_html_tag",
			"label": "Heading html tag",
			"options": [
				{
					"value": "h1",
					"label": "h1"
				},
				{
					"value": "h2",
					"label": "h2"
				},
				{
					"value": "h3",
					"label": "h3"
				},
				{
					"value": "h4",
					"label": "h4"
				},
				{
					"value": "h5",
					"label": "h5"
				},
				{
					"value": "h6",
					"label": "h6"
				},
				{
					"value": "p",
					"label": "p"
				},
				{
					"value": "span",
					"label": "span"
				},
				{
					"value": "div",
					"label": "div"
				}
			],
			"default": "p",
			"info": "The HTML tag used for the heading."
		},
		{
			"type": "header",
			"content": "t:content.appearance"
		},
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "t:settings.color_scheme",
			"default": "scheme-1"
		},
		{
			"type": "select",
			"id": "background_media",
			"label": "t:settings.background_media",
			"options": [
				{
					"value": "none",
					"label": "t:options.none"
				},
				{
					"value": "image",
					"label": "t:options.image"
				},
				{
					"value": "video",
					"label": "t:options.video"
				}
			],
			"default": "none"
		},
		{
			"type": "video",
			"id": "video",
			"label": "t:settings.video",
			"visible_if": "{{ section.settings.background_media == 'video' }}"
		},
		{
			"type": "select",
			"id": "video_position",
			"label": "t:settings.video_position",
			"options": [
				{
					"value": "cover",
					"label": "t:options.cover"
				},
				{
					"value": "contain",
					"label": "t:options.contain"
				}
			],
			"default": "cover",
			"visible_if": "{{ section.settings.background_media == 'video' }}"
		},
		{
			"type": "image_picker",
			"id": "background_image",
			"label": "t:settings.image",
			"visible_if": "{{ section.settings.background_media == 'image' }}"
		},
		{
			"type": "select",
			"id": "background_image_position",
			"label": "t:settings.image_position",
			"options": [
				{
					"value": "cover",
					"label": "t:options.cover"
				},
				{
					"value": "fit",
					"label": "t:options.fit"
				}
			],
			"default": "cover",
			"visible_if": "{{ section.settings.background_media == 'image' }}"
		},
		{
			"type": "select",
			"id": "border",
			"label": "t:settings.borders",
			"options": [
				{
					"value": "none",
					"label": "t:options.none"
				},
				{
					"value": "solid",
					"label": "t:options.solid"
				}
			],
			"default": "none"
		},
		{
			"type": "range",
			"id": "border_width",
			"min": 0,
			"max": 10,
			"step": 0.5,
			"unit": "px",
			"label": "t:settings.border_width",
			"default": 1,
			"visible_if": "{{ section.settings.border != 'none' }}"
		},
		{
			"type": "range",
			"id": "border_opacity",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "%",
			"label": "t:settings.border_opacity",
			"default": 100,
			"visible_if": "{{ section.settings.border != 'none' }}"
		},
		{
			"type": "range",
			"id": "border_radius",
			"label": "t:settings.border_radius",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 0
		},
		{
			"type": "checkbox",
			"id": "toggle_overlay",
			"label": "t:settings.background_overlay"
		},
		{
			"type": "color",
			"id": "overlay_color",
			"label": "t:settings.overlay_color",
			"alpha": true,
			"default": "#00000026",
			"visible_if": "{{ section.settings.toggle_overlay }}"
		},
		{
			"type": "select",
			"id": "overlay_style",
			"label": "t:settings.overlay_style",
			"options": [
				{
					"value": "solid",
					"label": "t:options.solid"
				},
				{
					"value": "gradient",
					"label": "t:options.gradient"
				}
			],
			"default": "solid",
			"visible_if": "{{ section.settings.toggle_overlay }}"
		},
		{
			"type": "select",
			"id": "gradient_direction",
			"label": "t:settings.gradient_direction",
			"options": [
				{
					"value": "to top",
					"label": "t:options.up"
				},
				{
					"value": "to bottom",
					"label": "t:options.down"
				}
			],
			"default": "to top",
			"visible_if": "{{ section.settings.toggle_overlay and section.settings.overlay_style == 'gradient' }}"
		},
		{
			"type": "header",
			"content": "t:content.padding"
		},
		{
			"type": "range",
			"id": "padding-block-start",
			"label": "t:settings.top",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 0
		},
		{
			"type": "range",
			"id": "padding-block-end",
			"label": "t:settings.bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 0
		}
	],
	"blocks": [
		{
			"type": "service",
			"name": "Service Item",
			"limit": 6,
			"settings": [
				{
					"type": "html",
					"id": "icon_html",
					"label": "Icon HTML (SVG)"
				},
				{
					"type": "image_picker",
					"id": "icon_image",
					"label": "Icon Image (if SVG is blank)"
				},
				{
					"type": "text",
					"id": "title",
					"label": "Title",
					"default": "Service Name"
				},
				{
					"type": "textarea",
					"id": "text",
					"label": "Description",
					"default": "Describe your service here."
				},
				{
					"type": "text",
					"id": "link_label",
					"label": "Link Label",
					"default": "More about this service"
				},
				{
					"type": "url",
					"id": "link_url",
					"label": "Link URL"
				}
			]
		}
	],
	"presets": [
		{
			"name": "General USPs",
			"category": "Custom",
			"blocks": [
				{
					"type": "service",
					"settings": {
						"title": "FAST HEAT-UP",
						"text": "Ready to go in seconds",
						"link_label": ""
					}
				},
				{
					"type": "service",
					"settings": {
						"title": "PURE FLAVOUR",
						"text": "Crisp vapor with precision",
						"link_label": ""
					}
				},
				{
					"type": "service",
					"settings": {
						"title": "EASY TO USE",
						"text": "Effortless enjoyment",
						"link_label": ""
					}
				},
				{
					"type": "service",
					"settings": {
						"title": "LONG BATTERY LIFE",
						"text": "Enjoy more sessions",
						"link_label": ""
					}
				}
			]
		}
	]
}
{% endschema %}